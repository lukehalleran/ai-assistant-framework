# Minimal .env for Docker - only essentials
# Let config/config.yaml control most settings

# ============================================================================
# REQUIRED: API Keys
# ============================================================================
OPENAI_API_KEY=your_openai_api_key_here

# ============================================================================
# OPTIONAL: Mode — "user" (streamlined) or "dev" (all features)
# ============================================================================
# DAEMON_MODE=user

# ============================================================================
# OPTIONAL: Additional API Keys (can also be set in config.yaml)
# ============================================================================
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# TAVILY_API_KEY=your_tavily_api_key_here
# WOLFRAM_APP_ID=your_wolfram_app_id_here
# E2B_API_KEY=your_e2b_api_key_here

# ============================================================================
# DOCKER-SPECIFIC: Network and Server
# ============================================================================
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_PORT=7860
GRADIO_SHARE=0
GRADIO_OPEN_BROWSER=0

# ============================================================================
# OPTIONAL: Paths (use defaults from config.yaml if not set)
# ============================================================================
# CORPUS_FILE=./data/corpus_v4.json
# CHROMA_PATH=./data/chroma_db_v4_v2

# ============================================================================
# OPTIONAL: Device Selection
# ============================================================================
CHROMA_DEVICE=cpu

# ============================================================================
# OPTIONAL: Hugging Face Offline Mode (models pre-baked in Docker image)
# ============================================================================
HF_HUB_OFFLINE=1
HF_HOME=/app/data/cache/huggingface
